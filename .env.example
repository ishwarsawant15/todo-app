# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit the real .env file.

# --- Postgres ---
POSTGRES_DB=todo_db
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Django ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated. Add your EC2 public IP and/or domain name here.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# Optional: auto-create a Django admin superuser on first boot.
# Leave blank to skip and create one manually with `docker compose exec backend python manage.py createsuperuser`.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
